{
  "name": "mathworld",
  "version": "1.0.0",
  "description": "Videojuego educativo de matemáticas para niños con discalculia (7-10 años)",
  "main": "index.html",
  "scripts": {
    "start": "npx serve . --listen 8080",
    "dev":   "npx live-server --port=8080 --open=/index.html",
    "build": "echo 'No build step required – pure HTML/CSS/JS'",
    "lint":  "npx eslint js/**/*.js"
  },
  "keywords": [
    "educación", "matemáticas", "discalculia", "niños",
    "videojuego", "html5", "javascript", "threejs", "gsap"
  ],
  "author": "MathWorld Team",
  "license": "MIT",
  "homepage": "https://tu-usuario.github.io/MathWorld",
  "repository": {
    "type": "git",
    "url": "https://github.com/tu-usuario/MathWorld.git"
  },
  "devDependencies": {
    "live-server": "^1.2.2",
    "serve": "^14.2.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
